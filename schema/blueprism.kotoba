// Blueprism clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace blueprism {

    entity Bot {
        id: string @unique
        name: string
        machine: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Process {
        id: string @unique
        name: string
        version: string
        published: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Job {
        id: string @unique
        processId: string
        botId: string
        status: string
        startedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Queue {
        id: string @unique
        name: string
        pending: integer
        priority: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Asset {
        id: string @unique
        name: string
        type: string
        valueRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity ProcessMining {
        id: string @unique
        name: string
        caseCount: integer
        variants: integer
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
